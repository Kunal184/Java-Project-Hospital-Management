<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>Hospital Patient Record System</display-name>

    <servlet>
        <servlet-name>AddPatientServlet</servlet-name>
        <servlet-class>com.hospital.servlet.AddPatientServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AddPatientServlet</servlet-name>
        <url-pattern>/addPatient</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>SearchPatientServlet</servlet-name>
        <servlet-class>com.hospital.servlet.SearchPatientServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SearchPatientServlet</servlet-name>
        <url-pattern>/searchPatient</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>DisplayPatientsServlet</servlet-name>
        <servlet-class>com.hospital.servlet.DisplayPatientsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DisplayPatientsServlet</servlet-name>
        <url-pattern>/displayPatients</url-pattern>
    </servlet-mapping>

    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>
</web-app>
